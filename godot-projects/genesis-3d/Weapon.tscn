 ── Weapon.tscn ──────────────────────────────────────────────
; ✅ إصلاح: إضافة ext_resource للـ bullet كان ناقصاً (load_steps كان 3 والآن 4)
[gd_scene load_steps=4 format=3 uid="uid://weapon"]

[ext_resource type="Script" path="res://Weapon.gd" id="1_script"]
[ext_resource type="PackedScene" uid="uid://bullet" path="res://Bullet.tscn" id="2_bullet"]

[sub_resource type="BoxMesh" id="1_box"]
size = Vector3(1, 1, 1)

[node name="Weapon" type="Node3D"]
script = ExtResource("1_script")
muzzle_point = NodePath("Muzzle")
bullet_scene = ExtResource("2_bullet")

[node name="MeshInstance3D" type="MeshInstance3D" parent="."]
transform = Transform3D(0.05, 0, 0, 0, 0.3, 0, 0, 0, 0.05, 0, -0.2, 0.5)
mesh = SubResource("1_box")

[node name="Muzzle" type="Node3D" parent="."]
position = Vector3(0, -0.1, 0.7)
